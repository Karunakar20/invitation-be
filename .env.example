# Copy to `.env` and adjust as needed.

# --- Database (used by the FastAPI app + Alembic) ---
DB_HOST=127.0.0.1
DB_PORT=6000
DB_NAME=wedding_db
DB_USER=user
DB_PASSWORD=user@1234

# Optional: if set, it takes precedence over DB_* above
# DATABASE_URL=postgresql+psycopg2://user:pass@127.0.0.1:6000/wedding_db

# --- JWT / security ---
SECRET_KEY=change-me
JWT_ALGORITHM=HS256

# --- Docker (Postgres container) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=user@1234
POSTGRES_DB=wedding_db
POSTGRES_HOST_PORT=6000

